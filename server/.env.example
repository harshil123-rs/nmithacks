PORT=3000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/lgtm?retryWrites=true&w=majority

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

# GitHub App
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_SLUG=tarin-lgtm

# Redis (Upstash / Redis Labs)
REDIS_URL=redis://default:password@host:port

# URLs — CHANGE THESE FOR PRODUCTION
CLIENT_URL=https://looksgoodtomeow.in
API_URL=https://api.looksgoodtomeow.in
WEBHOOK_BASE_URL=https://api.looksgoodtomeow.in

# SMTP (optional — for email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Dodo Payments
DODO_PAYMENTS_API_KEY=
DODO_WEBHOOK_SECRET=
DODO_PRODUCT_ID=
DODO_ENV=test_mode

# Sentry
SENTRY_DSN=

# ── n8n Integration (Problem Solvers) ────────────────────────────────────────
# n8n cloud webhook URL (your n8n instance sends code here, leave blank to skip)
N8N_WEBHOOK_URL=https://your-instance.app.n8n.cloud/webhook/review-code

# Discord webhook for critical/high severity alerts (optional)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Slack webhook for medium severity alerts (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Backend URL as seen from n8n cloud (use ngrok for local dev)
# Set this as an environment variable in n8n: BACKEND_URL
# Example: https://abc123.ngrok.io  or  https://api.yourdomain.com
